<?xml version="1.0" encoding="utf-8" ?>
<sf:PageBase x:Class="Starshot.Features.About.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starshot.Language"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starshot.Frameworks"
             mc:Ignorable="d">

    <ScrollViewer Padding="0">
        <StackPanel MaxWidth="720"
                    Padding="48,24,48,48"
                    Spacing="20">

            <Grid Margin="0,0,0,0">
                <TextBlock VerticalAlignment="Top"
                           FontSize="32"
                           FontWeight="Bold"
                           Text="{x:Bind lang:Lang.Starshot_Nav_About}" />
                <Image Width="96"
                       Height="96"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Top"
                       Source="ms-appx:///Assets/logo.png" />
            </Grid>

            <Border Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock FontSize="22" FontWeight="SemiBold" Text="Starshot" />
                        <Border Padding="8,2,8,2"
                                VerticalAlignment="Center"
                                Background="{ThemeResource AccentFillColorDefaultBrush}"
                                CornerRadius="4">
                            <TextBlock FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextOnAccentFillColorDefaultBrush}"
                                       Text="{x:Bind Version}" />
                        </Border>
                    </StackPanel>
                    <TextBlock Margin="0,4,0,0"
                               FontWeight="SemiBold"
                               Text="{x:Bind lang:Lang.Starshot_AboutTagline}" />
                    <TextBlock FontSize="13"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="{x:Bind lang:Lang.Starshot_AboutDesc}"
                               TextWrapping="Wrap" />
                    <StackPanel Margin="0,8,0,0"
                                Orientation="Horizontal"
                                Spacing="6">
                        <TextBlock FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind lang:Lang.Starshot_AboutProjectHome}" />
                        <TextBlock FontSize="13">
                            <Hyperlink NavigateUri="https://github.com/loliri/Starshot" UnderlineStyle="None">
                                <Run Text="https://github.com/loliri/Starshot" />
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>

            <TextBlock Margin="0,4,0,0"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Text="{x:Bind lang:Lang.Starshot_AboutThanksTitle}" />

            <StackPanel Padding="24,12,24,12"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Spacing="10">

                <TextBlock FontSize="13" TextWrapping="Wrap">
                    <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="•  " />
                    <Hyperlink NavigateUri="https://github.com/Scighost/Starward" UnderlineStyle="None">
                        <Run FontWeight="SemiBold" Text="Starward" />
                    </Hyperlink>
                    <Run Text=" — " />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.Starshot_AboutThanksStarward}" />
                </TextBlock>

                <TextBlock FontSize="13" TextWrapping="Wrap">
                    <Run Foreground="{ThemeResource TextFillColorTertiaryBrush}" Text="•  " />
                    <Hyperlink NavigateUri="https://github.com/ShareX/ShareX" UnderlineStyle="None">
                        <Run FontWeight="SemiBold" Text="ShareX" />
                    </Hyperlink>
                    <Run Text=" — " />
                    <Run Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind lang:Lang.Starshot_AboutThanksShareX}" />
                </TextBlock>

            </StackPanel>

            <StackPanel Margin="0,8,0,0"
                        Orientation="Horizontal"
                        Spacing="12">
                <Button Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind OpenDataFolderCommand}"
                        CornerRadius="8,20,20,8"
                        Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE8DA;" />
                        <TextBlock Text="{x:Bind lang:Lang.Starshot_AboutOpenDataFolder}" />
                    </StackPanel>
                </Button>
                <Button x:Name="CheckUpdateButton"
                        Height="40"
                        Padding="16,0,16,0"
                        BorderThickness="0"
                        Command="{x:Bind CheckUpdateCommand}"
                        CornerRadius="8,20,20,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon FontSize="14" Glyph="&#xE72C;" />
                        <TextBlock Text="{x:Bind lang:Lang.Starshot_CheckUpdate}" />
                    </StackPanel>
                </Button>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</sf:PageBase>
