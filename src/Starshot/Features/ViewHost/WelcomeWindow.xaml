<?xml version="1.0" encoding="utf-8" ?>
<sf:WindowEx x:Class="Starshot.Features.ViewHost.WelcomeWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lang="using:Starshot.Language"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:sf="using:Starshot.Frameworks"
             Title="Starshot"
             x:DefaultBindMode="OneWay"
             mc:Ignorable="d">

    <Grid Loaded="Grid_Loaded">
        <Image Source="ms-appx:///Assets/vandesart.jpg" Stretch="UniformToFill" />
        <Rectangle Fill="{ThemeResource ControlOnImageFillColorDefaultBrush}" />

        <StackPanel Margin="48,0,48,0" VerticalAlignment="Center" Spacing="20">

            <!--  欢迎  -->
            <TextBlock FontSize="24"
                       FontWeight="Bold"
                       Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeHello}" />
            <TextBlock FontSize="15"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeIntro}"
                       TextWrapping="Wrap" />

            <!--  DXGI 接口检测  -->
            <TextBlock Margin="0,12,0,0"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeDxgiTitle}" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock VerticalAlignment="Center"
                           FontSize="14"
                           Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                           Text="{x:Bind lang:Lang.Starshot_WelcomeDxgiSupported}"
                           Visibility="{x:Bind DxgiSupported}" />
                <StackPanel Visibility="{x:Bind DxgiNotSupported}">
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               Text="{x:Bind lang:Lang.Starshot_WelcomeDxgiNotSupported1}"
                               TextWrapping="Wrap" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               Text="{x:Bind lang:Lang.Starshot_WelcomeDxgiNotSupported2}"
                               TextWrapping="Wrap" />
                    <TextBlock VerticalAlignment="Center"
                               FontSize="14"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               Text="{x:Bind lang:Lang.Starshot_WelcomeDxgiNotSupported3}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </StackPanel>

            <!--  自定义壁纸  -->
            <TextBlock Margin="0,12,0,0"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeWallpaperTitle}" />
            <TextBlock FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeWallpaperDesc}"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button BorderThickness="0"
                        Command="{x:Bind PickWallpaperCommand}"
                        Content="{x:Bind lang:Lang.Starshot_WelcomePickWallpaper}"
                        Style="{ThemeResource AccentButtonStyle}" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind WallpaperDisplay}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

            <!--  截图存放位置  -->
            <TextBlock Margin="0,12,0,0"
                       FontSize="16"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeScreenshotFolderTitle}" />
            <TextBlock FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="{x:Bind lang:Lang.Starshot_WelcomeScreenshotFolderDesc}"
                       TextWrapping="Wrap" />
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button BorderThickness="0"
                        Command="{x:Bind PickScreenshotFolderCommand}"
                        Content="{x:Bind lang:Lang.Starshot_WelcomePickFolder}"
                        Style="{ThemeResource AccentButtonStyle}" />
                <TextBlock VerticalAlignment="Center"
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind ScreenshotFolderDisplay}"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>

        </StackPanel>

        <!--  开始使用  -->
        <Button Height="40"
                Margin="0,0,80,48"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                BorderThickness="0"
                Command="{x:Bind StartCommand}"
                CornerRadius="8,20,20,8"
                Style="{ThemeResource AccentButtonStyle}">
            <TextBlock Margin="4,0,8,0" FontSize="14" Text="{x:Bind lang:Lang.Starshot_WelcomeStart}" />
        </Button>

    </Grid>

</sf:WindowEx>
